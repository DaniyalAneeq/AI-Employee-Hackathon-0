# AI Employee Gold Tier Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git — it contains secrets

# Vault path (absolute path to your Obsidian vault)
VAULT_PATH=./vault

# Drop folder path (where you drop files for the watcher)
DROP_FOLDER_PATH=./drop_folder

# Watcher check interval in seconds (filesystem watcher)
WATCHER_INTERVAL=5

# Dry run mode (true = log actions without executing, false = execute actions)
DRY_RUN=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# --- Gmail ---
# Path to Google OAuth client credentials JSON (Desktop App type)
# Download from: Google Cloud Console > APIs & Services > Credentials
GMAIL_CREDENTIALS_PATH=../gmail_credentials.json

# Path to store the OAuth token after first auth
GMAIL_TOKEN_PATH=../gmail_token.json

# Gmail polling interval in seconds
GMAIL_CHECK_INTERVAL=120

# Gmail search query for fetching emails
# Testing: is:unread    Production: is:unread is:important
GMAIL_QUERY=is:unread is:important

# Max emails to fetch per poll
GMAIL_MAX_RESULTS=10

# --- LinkedIn / Playwright ---
# Path to store the LinkedIn browser session (created by setup_linkedin_session.py)
LINKEDIN_SESSION_PATH=./.linkedin_session

# How often to poll LinkedIn for messages/notifications (seconds)
LINKEDIN_CHECK_INTERVAL=300

# Run LinkedIn browser in headless mode (true after setup, false during setup_linkedin_session.py)
LINKEDIN_HEADLESS=false

# Max LinkedIn posts per hour
LINKEDIN_POST_RATE_LIMIT=3

# --- Rate Limits ---
# Max emails per hour
EMAIL_RATE_LIMIT=10

# --- Scheduling ---
# Daily briefing time (24h format)
DAILY_BRIEFING_HOUR=8
DAILY_BRIEFING_MINUTE=0

# --- Approval ---
# How often to check for approved actions (seconds)
APPROVAL_CHECK_INTERVAL=10

# =============================================================================
# GOLD TIER — ODOO COMMUNITY ERP
# =============================================================================
# Setup: run  bash gold/scripts/setup_odoo.sh  first
# Reference: https://www.odoo.com/documentation/19.0/developer/reference/external_api.html

# Odoo server URL (default: local install)
ODOO_URL=http://localhost:8069

# Odoo database name (created by setup_odoo.sh)
ODOO_DB=odoo_ai_employee

# Odoo admin credentials
ODOO_USER=admin
ODOO_PASSWORD=admin

# =============================================================================
# GOLD TIER — META SOCIAL MEDIA (Facebook + Instagram Graph API)
# =============================================================================
# Setup: Create a Meta Developer App at https://developers.facebook.com/
# Required: Facebook Page + Instagram Business Account linked to the page
# Permissions needed: pages_manage_posts, pages_read_engagement, publish_pages
#                     instagram_basic, instagram_content_publish

# Facebook Page ID (found in Page Settings > About)
META_PAGE_ID=

# Facebook Page Access Token (long-lived, from Graph API Explorer)
META_PAGE_ACCESS_TOKEN=

# Instagram Business Account ID (linked to your Facebook page)
# Find: Graph API Explorer → GET /me/accounts → instagram_business_account.id
META_IG_USER_ID=

# Meta Graph API version
META_GRAPH_API_VERSION=v19.0

# Max Meta posts per hour (rate limiting)
META_POST_RATE_LIMIT=3
